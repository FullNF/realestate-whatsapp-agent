# Copy to .env for local testing. On Render, set these in the dashboard
# (or via render.yaml) instead — never commit a real .env file.

# --- App ---
APP_NAME=Real Estate WhatsApp Agent
ENV=production
LOG_LEVEL=INFO

# --- Database (Neon Postgres - see README for setup) ---
# Get this from your Neon project dashboard. Must include sslmode=require.
DATABASE_URL=postgresql+psycopg2://user:password@host.neon.tech/dbname?sslmode=require

# --- Meta WhatsApp Cloud API (see README for full setup from scratch) ---
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=choose-any-random-string-here
META_APP_SECRET=
META_API_VERSION=v21.0

# --- Groq (free LLM - get a key at console.groq.com) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Business rules ---
BUSINESS_NAME=YouWe Realty
AGENT_NAME=Riya
# Comma-separated, e.g. "Sector 70,Sector 69,Sector 71"
SERVICE_AREAS=Sector 70
OUT_OF_AREA_MAX_ATTEMPTS=4
DISCLOSE_AI=true

# --- Admin ---
ADMIN_API_KEY=choose-a-long-random-string-here
# Your own WhatsApp number (with country code, no +, no spaces) to get
# pinged about paused leads and hot leads. Leave blank to disable.
ADMIN_NOTIFY_PHONE=
